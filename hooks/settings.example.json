{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun $GTMOPS_DIR/hooks/gtmops-error-review.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun $GTMOPS_DIR/hooks/gtmops-guard.ts"
          }
        ]
      }
    ]
  }
}
