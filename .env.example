# GTMOps Environment Variables
# Copy to .env and fill in your API keys

# Instantly v2 (cold email)
INSTANTLY_API_KEY=

# Slack (channel management + Slack Connect)
SLACK_BOT_TOKEN=

# Attio v2 (CRM)
ATTIO_API_KEY=

# Pylon (customer success)
PYLON_API_KEY=

# Gamma (presentation generation)
GAMMA_API_KEY=

# Zoho Bigin (CRM - OAuth2)
BIGIN_CLIENT_ID=
BIGIN_CLIENT_SECRET=
BIGIN_REFRESH_TOKEN=

# n8n (workflow automation)
# VPS instance (self-hosted)
N8N_API_KEY=
N8N_VPS_URL=http://localhost:5678

# n8n Cloud instance (optional)
N8N_CLOUD_API_KEY=
N8N_CLOUD_URL=

# Serper.dev (Google Search, Maps, Reviews)
SERPER_API_KEY=

# Firecrawl (web scraping + search)
FIRECRAWL_API_KEY=

